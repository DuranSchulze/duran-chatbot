{
  "name": "duran-chatbot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/admin",
    "dev:widget": "npm run dev --workspace=packages/widget",
    "build": "npm run build --workspace=packages/config && npm run build --workspace=packages/widget && npm run build --workspace=apps/admin",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^9.39.4",
    "typescript": "~5.9.3"
  },
  "license": "ISC",
  "dependencies": {
    "googleapis": "^146.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.7.0",
    "nodemailer": "^8.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^5.11.0"
  }
}
